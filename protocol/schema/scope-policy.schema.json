{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tracelink:schema:scope-policy",
  "title": "TraceLink Scope policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["enabled"],
  "properties": {
    "enabled": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "known": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "revision": { "type": "integer", "minimum": 0 }
  }
}
